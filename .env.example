# API keys (server-side only — never prefix with VITE_)
GROQ_API_KEY=your_groq_api_key_here

# Optional: RapidAPI key for Judge0 CE (falls back to free public Judge0)
# RAPIDAPI_KEY=your_rapidapi_key_here

# Collab server URL (client-side)
VITE_SOCKET_URL=http://localhost:3001

# Local dev API port (optional)
API_PORT=3000

# Optional: override Judge0 compiler URL
# JUDGE0_API_URL=https://ce.judge0.com
